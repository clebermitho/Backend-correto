# ══════════════════════════════════════════════════════════════
# Chatplay Backend v1.1 — Configuração de Ambiente
# ══════════════════════════════════════════════════════════════
# Copie para .env e preencha ANTES de iniciar.
# NUNCA versione .env com valores reais.
#
# Gerar JWT_SECRET:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ══════════════════════════════════════════════════════════════

# ── Banco de dados (OBRIGATÓRIO - SUPABASE POOLER) ─────────────
# DATABASE_URL: Use a URL do "Transaction Mode" do Supavisor (Porta 6543)
#   - ✅ USUÁRIO: OBRIGATÓRIO incluir o project ref (ex: postgres.abcdefg...)
#   - ✅ SENHA: Se tiver caracteres especiais (@, #, !, $), você DEVE codificá-los (ex: @ vira %40)
#   - ✅ PARÂMETROS: Adicione ?pgbouncer=true&connection_limit=1 no final.
DATABASE_URL="postgresql://postgres.[SEU_PROJECT_REF]:[SUA_SENHA_CODIFICADA]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Use a URL de "Session Mode" ou Conexão Direta (Porta 5432)
#   - Usado pelo Prisma APENAS para migrações (npx prisma migrate deploy).
DIRECT_URL="postgresql://postgres.[SEU_PROJECT_REF]:[SUA_SENHA_CODIFICADA]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ── Segurança JWT (OBRIGATÓRIO) ──────────────────────────────
JWT_SECRET="TROQUE_POR_64_CHARS_ALEATORIOS"
JWT_TTL_HOURS=8
# Duração do refresh token em dias (padrão: 30)
JWT_REFRESH_DAYS=30

# ── Bootstrap do primeiro admin (OBRIGATÓRIO para /api/auth/register) ──
ADMIN_BOOTSTRAP_SECRET="TROQUE_POR_SEGREDO_UNICO"

# ── OpenAI (OBRIGATÓRIO para endpoints /api/ai/*) ────────────
# Esta chave NUNCA deve ir para a extensão ou admin.
OPENAI_API_KEY="sk-..."
# Modelo OpenAI (padrão: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# ── CORS — origens permitidas (separadas por vírgula) ────────
# Extensões Chrome/Edge (chrome-extension://) são ACEITAS AUTOMATICAMENTE — não precisa configurar.
# Adicione aqui apenas origens web adicionais (painel admin hospedado, etc.)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
