# ── .env.docker — variáveis para docker-compose ──────────────
# Copie este arquivo para .env antes de rodar docker-compose up
# NÃO versione o .env com valores reais

POSTGRES_USER=chatplay
POSTGRES_PASSWORD=chatplay_dev_senha
POSTGRES_DB=chatplay_db

JWT_SECRET=troque-por-string-aleatoria-64-chars-producao
JWT_TTL_HOURS=8

OPENAI_API_KEY=sk-...

ADMIN_BOOTSTRAP_SECRET=troque-por-segredo-de-bootstrap

# Origens CORS permitidas (admin + extensão)
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://SEU_EXTENSION_ID
